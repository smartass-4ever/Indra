# Bright Data — required for production mode
# Get your API key and create a zone at https://brightdata.com
BRIGHTDATA_API_KEY=your-bright-data-api-key
BRIGHTDATA_UNLOCKER_ZONE=your-zone-name   # e.g. web_unlocker1
BRIGHTDATA_SERP_ZONE=your-serp-zone-name  # optional, for search_watch()

# LLM — optional (enables AI analysis on changes, otherwise raw diffs returned)
ANTHROPIC_API_KEY=your-anthropic-api-key
